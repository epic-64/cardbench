{
  "id": "dev-deck-2player",
  "name": "Dev Deck (2P, shared play)",
  "players": 2,
  "catalog": {
    "cards": [
      { "id": "build", "color": "#3b82f6", "title": "Build", "description": "Deal 1 Feature into your Build.\nDeal 2 Tech Debt into your Deck, then shuffle it.", "corners": { "topRight": "1" } },
      { "id": "refactor", "color": "#22c55e", "title": "Refactor", "description": "Remove 2 debt cards from your deck or discard pile. (back to the Tech Debt stack)", "corners": { "topRight": "1" } },
      { "id": "test", "color": "#eab308", "title": "Test", "description": "Add this Test to your build to protect against bugs. (Card can be sacrificed instead of a Feature)" },
      { "id": "backup", "color": "#a855f7", "title": "Backup", "description": "Add this backup to your build to protect against data loss. (Card can be sacrificed instead of Features)" },
      { "id": "debt", "color": "#6b7280", "title": "Tech Debt", "description": "Dead weight. Clogs your hand." },
      { "id": "crunch", "color": "#f97316", "title": "Crunch", "description": "EXTRA ACTION.\nAdd a Tech Debt to your deck, then play an additional card this turn." },
      { "id": "modular-design", "color": "#14b8a6", "title": "Modular Design", "description": "Discard 3 Features.\nChoose 1 card from the Feature deck and add it to your build. Shuffle the Feature deck." },
      { "id": "feature-green", "color": "#16a34a", "title": "Feature (Green)", "description": "A green feature." },
      { "id": "feature-blue", "color": "#2563eb", "title": "Feature (Blue)", "description": "A blue feature." },
      { "id": "feature-red", "color": "#ef4444", "title": "Feature (Red)", "description": "A red feature." },
      { "id": "bug", "color": "#dc2626", "title": "Bug", "description": "Delete one feature or test from your build." },
      { "id": "data-loss", "color": "#7f1d1d", "title": "Data Loss", "description": "For every tech debt in your hand, delete one feature from your build." },
      { "id": "stakeholder-pivot", "color": "#db2777", "title": "Stakeholder Pivot", "description": "Discard the leftmost feature of the customer project, and replace it with the top card of the feature deck." },
      { "id": "burnout", "color": "#ea580c", "title": "Burnout", "description": "If you have two or more tech debt cards, discard one non-debt card from your hand." },
      { "id": "ci-cd", "color": "#0891b2", "title": "CI/CD", "description": "If you have a test in your build:\ndraw a card.\ngain one extra action this turn." },
      { "id": "rule-taking-a-turn", "color": "#888888", "title": "Taking a Turn", "description": "1. Draw 4 cards from your deck.\n2. Reveal an event and execute it.\n3. Play one card from your hand.\n4. Discard your hand.\n5. End turn." },
      { "id": "rule-preparation", "color": "#888888", "title": "Preparation", "description": "1. Deal 3 Feature cards into the global Project Zone, face up." },
      { "id": "rule-winning", "color": "#888888", "title": "Winning the Game", "description": "The first to collect 8 Feature cards wins. When you have 3 Feature cards in your Build Zone, that match the colors of the Project, you can deliver the project. Move the 3 Feature cards into your Points Zone" }
    ]
  },
  "rulebook": {
    "rules": [
      {
        "trigger": { "$type": "Moved", "card": "build", "to": "play" },
        "effects": [
          { "$type": "Deal", "from": "features", "to": { "role": "build" } },
          { "$type": "Deal", "from": "debt", "to": { "role": "deck" }, "count": 2 },
          { "$type": "Shuffle", "stack": { "role": "deck" } },
          { "$type": "Deal", "from": "play", "to": { "role": "discard" } }
        ]
      },
      {
        "trigger": { "$type": "Moved", "card": "debt", "to": "play" },
        "effects": [
          { "$type": "Manual", "description": "Resolve the Tech Debt, then send it back." },
          { "$type": "Deal", "from": "play", "to": "debt" }
        ]
      }
    ]
  },
  "setup": {
    "stacks": [
      { "id": "feature-discard", "label": "Feature Discard", "position": { "x": 80, "y": 0 }, "facing": "up", "contents": [], "group": "group-2" },
      { "id": "project-zone", "label": "Project Zone", "position": { "x": 400, "y": 0 }, "facing": "up", "contents": [], "layout": "row", "group": "group-2" },
      { "id": "debt", "label": "Tech Debt", "position": { "x": 1200, "y": 0 }, "facing": "down", "contents": [ { "card": "debt", "count": 30 } ], "group": "group-2" },
      { "id": "features", "label": "Feature Deck", "position": { "x": 220, "y": 0 }, "facing": "down", "contents": [ { "card": "feature-green", "count": 10 }, { "card": "feature-blue", "count": 10 }, { "card": "feature-red", "count": 10 } ], "arrangement": "shuffled", "group": "group-2" },
      { "id": "events", "label": "Event Deck", "position": { "x": 980, "y": 0 }, "facing": "down", "contents": [ { "card": "bug", "count": 3 }, { "card": "data-loss", "count": 2 }, { "card": "stakeholder-pivot", "count": 2 }, { "card": "burnout", "count": 2 }, { "card": "ci-cd", "count": 2 } ], "arrangement": "shuffled", "group": "group-2" },
      { "id": "event-discard", "label": "Event Discard", "position": { "x": 840, "y": 0 }, "facing": "up", "contents": [], "group": "group-2" },
      { "id": "play", "label": "Play Zone (shared)", "position": { "x": 580, "y": 740 }, "facing": "up", "contents": [], "width": 1, "group": "group-2" },
      { "id": "deck1", "label": "Deck 1", "position": { "x": 140, "y": 740 }, "facing": "down", "contents": [ { "card": "build", "count": 8 }, { "card": "refactor", "count": 4 }, { "card": "crunch", "count": 2 }, { "card": "modular-design", "count": 2 }, { "card": "test", "count": 2 }, { "card": "backup", "count": 2 } ], "arrangement": "shuffled", "group": "group-0", "owner": 0, "role": "deck" },
      { "id": "hand1", "label": "Hand 1", "position": { "x": 0, "y": 500 }, "facing": "up", "contents": [], "layout": "row", "width": 4, "group": "group-0", "owner": 0, "role": "hand" },
      { "id": "build1", "label": "Build Zone 1", "position": { "x": 0, "y": 260 }, "facing": "up", "contents": [], "layout": "row", "group": "group-0", "owner": 0, "role": "build" },
      { "id": "discard1", "label": "Discard 1", "position": { "x": 0, "y": 740 }, "facing": "up", "contents": [], "group": "group-0", "owner": 0, "role": "discard" },
      { "id": "deck2", "label": "Deck 2", "position": { "x": 1120, "y": 740 }, "facing": "down", "contents": [ { "card": "build", "count": 8 }, { "card": "refactor", "count": 4 }, { "card": "crunch", "count": 2 }, { "card": "modular-design", "count": 2 }, { "card": "test", "count": 2 }, { "card": "backup", "count": 2 } ], "arrangement": "shuffled", "group": "group-1", "owner": 1, "role": "deck" },
      { "id": "hand2", "label": "Hand 2", "position": { "x": 980, "y": 500 }, "facing": "up", "contents": [], "layout": "row", "width": 4, "group": "group-1", "owner": 1, "role": "hand" },
      { "id": "build2", "label": "Build Zone 2", "position": { "x": 980, "y": 260 }, "facing": "up", "contents": [], "layout": "row", "group": "group-1", "owner": 1, "role": "build" },
      { "id": "discard2", "label": "Discard 2", "position": { "x": 980, "y": 740 }, "facing": "up", "contents": [], "group": "group-1", "owner": 1, "role": "discard" }
    ],
    "buttons": [
      { "stackId": "hand1", "label": "draw 4", "effects": [ { "$type": "Deal", "from": { "role": "deck" }, "to": { "role": "hand" }, "count": 4 } ] },
      { "stackId": "hand1", "label": "discard", "effects": [ { "$type": "Deal", "from": { "role": "hand" }, "to": { "role": "discard" }, "count": 10 } ] },
      { "stackId": "discard1", "label": "refresh deck", "effects": [ { "$type": "Deal", "from": { "role": "discard" }, "to": { "role": "deck" }, "count": 100 }, { "$type": "Shuffle", "stack": { "role": "deck" } } ] },
      { "stackId": "hand2", "label": "draw 4", "effects": [ { "$type": "Deal", "from": { "role": "deck" }, "to": { "role": "hand" }, "count": 4 } ] },
      { "stackId": "hand2", "label": "discard", "effects": [ { "$type": "Deal", "from": { "role": "hand" }, "to": { "role": "discard" }, "count": 10 } ] },
      { "stackId": "discard2", "label": "refresh deck", "effects": [ { "$type": "Deal", "from": { "role": "discard" }, "to": { "role": "deck" }, "count": 100 }, { "$type": "Shuffle", "stack": { "role": "deck" } } ] },
      { "stackId": "event-discard", "label": "refresh events", "effects": [ { "$type": "Deal", "from": "event-discard", "to": "events", "count": 100 } ] },
      { "stackId": "feature-discard", "label": "refresh features", "effects": [ { "$type": "Deal", "from": "feature-discard", "to": "features", "count": 100 } ] },
      { "stackId": "project-zone", "label": "new project", "effects": [ { "$type": "Deal", "from": "features", "to": "project-zone", "count": 3 } ] },
      { "stackId": "play", "label": "end turn", "effects": [ { "$type": "EndTurn" } ] }
    ],
    "groups": [
      { "id": "group-0", "name": "Player 1" },
      { "id": "group-1", "name": "Player 2" },
      { "id": "group-2", "name": "Global" }
    ]
  },
  "layout": {
    "width": 130,
    "height": 180,
    "background": "#16161f",
    "titleFont": 80,
    "descriptionFont": 70,
    "corner": { "shape": "circle", "fill": "outline", "font": "inherit" }
  }
}
